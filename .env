# --------------------------
# Baza danych (PostgreSQL)
# --------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mydb
POSTGRES_PORT=5432

# Baza testowa (docker-compose.test.yml)
POSTGRES_TEST_DB=mydb_test

# --------------------------
# Backend (Spring Boot)
# --------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/mydb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Backend testowy
SPRING_DATASOURCE_TEST_URL=jdbc:postgresql://db:5432/mydb_test
SPRING_DATASOURCE_TEST_USERNAME=postgres
SPRING_DATASOURCE_TEST_PASSWORD=postgres

# --------------------------
# Frontend (React / Vite)
# --------------------------
REACT_APP_API_URL=http://localhost:8080/api
